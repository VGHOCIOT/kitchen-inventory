# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=admin
POSTGRES_PASSWORD=changeme
POSTGRES_DB=inventory
DATABASE_URL=postgresql+asyncpg://admin:changeme@db:5432/inventory

# ── API Keys ──────────────────────────────────────────────────────────────────
# Anthropic — required for receipt scanning (Claude Vision)
ANTHROPIC_API_KEY=sk-ant-...

# Spoonacular — required for recipe import
SPOONACULAR_API_KEY=your_spoonacular_key

# USDA FoodData Central — required for ingredient weight lookups
USDA_API_KEY=your_usda_key

# ── App Config ────────────────────────────────────────────────────────────────
# Set to true if running behind a reverse proxy (e.g. Nginx Proxy Manager)
USE_REVERSE_PROXY=false

# ── Storage ───────────────────────────────────────────────────────────────────
# Host path where receipt images are persisted on the host machine.
# Receipt parsing works entirely in-memory — images are only written to disk
# if you want an audit trail or to support reprocessing without re-uploading.
# The volume is always mounted; disk writes are opt-in (future SAVE_RECEIPT_IMAGES flag).
# Defaults to ./data/receipts relative to the project root if not set.
# Unraid example: /mnt/user/appdata/kitchen-inventory/receipts
# VPS example:    /opt/kitchen/receipts
RECEIPTS_HOST_PATH=./data/receipts

/* MagicMirror config example for Kitchen Inventory module.
 *
 * Copy this file to your MagicMirror config directory and merge
 * the module entry into your existing config.js.
 */
var config = {
  modules: [
    {
      module: "MMM-KitchenInventory",
      position: "top_left", // Pick any MagicMirror region
      config: {
        apiBaseUrl: "http://api:8000", // Docker service name, or use host IP
        updateInterval: 60 * 1000, // Poll interval in ms
        animationSpeed: 400,
        maxItems: 20,
        showLocation: true,
        locations: ["Fridge", "Freezer", "Cupboard"],
      },
    },
  ],
};

/*************** DO NOT EDIT THE LINE BELOW ***************/
if (typeof module !== "undefined") {
  module.exports = config;
}
